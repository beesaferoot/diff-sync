# Copy to deploy/.env and fill in. Loaded by docker compose via --env-file.

# Prebuilt image to RUN on the VPS (pushed by CI to GHCR). Defaults to
# diff-sync:local (the locally-built tag) if unset. Set this on the VPS.
IMAGE=ghcr.io/<owner>/diff-sync:latest

# Interface to bind the WS/HTTP port (8081) on. 127.0.0.1 (default) = loopback
# only, reachable by host nginx; set 0.0.0.0 only if exposing directly.
HTTP_BIND=127.0.0.1

# Public domain — informational here; the live value lives in the host nginx
# site config (/etc/nginx/sites-available/diff-sync) and certbot.
DOMAIN=diffsync.example.com
